# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tracktheirprofile"

# Authentication (REQUIRED in production)
JWT_SECRET="your-random-secret-here-min-32-chars"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Brave Search API (for deep Reddit search, optional, get key at https://api.search.brave.com)
BRAVE_SEARCH_API_KEY=

# Admin Dashboard (REQUIRED in production)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Cloudflare Turnstile (bot protection on login/signup - leave blank to disable)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Polar.sh Payments ($9 lifetime unlock)
# Get these from https://polar.sh/dashboard → Settings → API Keys & Webhooks
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=

# Email, Resend (https://resend.com)
# Used for new-user signup notifications AND admin → user emails from the dashboard.
# Verify the sending domain (tracktheirprofile.com) in Resend before going live.
RESEND_API_KEY=
SUPPORT_EMAIL_FROM="TrackTheirProfile Support <support@tracktheirprofile.com>"
# Replies to outgoing emails land here. Set to your real inbox (e.g. alyamjadshah@gmail.com).
SUPPORT_REPLY_TO=
ADMIN_NOTIFICATION_EMAIL=

# Legacy SMTP_* vars are still read as a fallback (SMTP_PASS == RESEND_API_KEY,
# SMTP_FROM == SUPPORT_EMAIL_FROM). Prefer the Resend-prefixed names above.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Application
APP_URL=http://localhost:3000
NODE_ENV=development
